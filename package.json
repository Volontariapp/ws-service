{
  "name": "ws-service",
  "version": "0.0.1",
  "type": "module",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:local": "NODE_ENV=local nest start --watch",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:test": "NODE_ENV=test nest start --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --passWithNoTests",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "node --loader ts-node/esm ./node_modules/typeorm/cli.js",
    "migration:generate": "yarn typeorm migration:generate -d src/config/data-source.ts",
    "migration:run:local": "NODE_ENV=local yarn typeorm migration:run -d src/config/data-source.ts",
    "migration:run:dev": "NODE_ENV=development yarn typeorm migration:run -d src/config/data-source.ts",
    "migration:run:test": "NODE_ENV=test yarn typeorm migration:run -d src/config/data-source.ts",
    "migration:run:prod": "NODE_ENV=production yarn typeorm migration:run -d src/config/data-source.ts",
    "migration:revert:local": "NODE_ENV=local yarn typeorm migration:revert -d src/config/data-source.ts",
    "migration:revert:dev": "NODE_ENV=development yarn typeorm migration:revert -d src/config/data-source.ts",
    "migration:revert:test": "NODE_ENV=test yarn typeorm migration:revert -d src/config/data-source.ts",
    "migration:revert:prod": "NODE_ENV=production yarn typeorm migration:revert -d src/config/data-source.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.6.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@volontariapp/auth": "^3.3.1",
    "@volontariapp/bridge-nest": "^0.3.15",
    "@volontariapp/config": "^3.2.0",
    "@volontariapp/contracts": "^4.0.14",
    "@volontariapp/contracts-nest": "^3.1.6",
    "@volontariapp/domain-event": "^3.4.0",
    "@volontariapp/errors": "^0.6.0",
    "@volontariapp/errors-nest": "^0.13.0",
    "@volontariapp/eslint-config": "^2.2.4",
    "@volontariapp/health-check": "^1.0.4",
    "@volontariapp/health-check-nest": "^0.1.35",
    "@volontariapp/logger": "^0.2.5",
    "@volontariapp/messaging": "^2.7.0",
    "@volontariapp/monitoring": "^2.1.5",
    "@volontariapp/post-processors": "^3.0.1",
    "@volontariapp/shared": "^0.6.1",
    "@volontariapp/validation-nest": "^0.1.3",
    "axios": "^1.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.0.2",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io-adapter": "^2.5.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@volontariapp/auth": "^3.3.1",
    "@volontariapp/bridge-nest": "^0.3.15",
    "@volontariapp/config": "^3.2.0",
    "@volontariapp/contracts": "^4.0.14",
    "@volontariapp/contracts-nest": "^3.1.6",
    "@volontariapp/domain-event": "^3.4.0",
    "@volontariapp/errors": "^0.6.0",
    "@volontariapp/errors-nest": "^0.13.0",
    "@volontariapp/eslint-config": "^2.2.4",
    "@volontariapp/health-check": "^1.0.4",
    "@volontariapp/health-check-nest": "^0.1.35",
    "@volontariapp/logger": "^0.2.5",
    "@volontariapp/messaging": "^2.7.0",
    "@volontariapp/monitoring": "^2.1.5",
    "@volontariapp/post-processors": "^3.0.1",
    "@volontariapp/shared": "^0.6.1",
    "@volontariapp/testing": "^1.0.1",
    "@volontariapp/validation-nest": "^0.1.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^15.4.0",
    "prettier": "3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack": "^5.97.1"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^(\\.\\.?/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ]
  }
}
