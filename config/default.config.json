{
  "db": {
    "host": "localhost",
    "port": 5436,
    "username": "user",
    "password": "password",
    "database": "ms_ws",
    "maxPoolSize": 10,
    "ssl": false
  },
  "logger": {
    "level": "info",
    "format": "text"
  },
  "auth": {
    "internalPublicKeyPath": "certs/internal.pub",
    "accessTokenPublicKeyPath": "certs/access.pub"
  },
  "microServices": {
    "msUserUrl": "localhost:5001",
    "msPostUrl": "localhost:5002",
    "msEventUrl": "localhost:5003"
  },
  "redis": {
    "host": "localhost",
    "port": 6380,
    "password": "password",
    "db": 0
  },
  "globalRedis": {
    "host": "localhost",
    "port": 6379,
    "password": "password",
    "db": 0
  },
  "postProcessor": {
    "groupName": "post-processor-ws",
    "streamName": "stream:ws",
    "batchSize": 1,
    "blockTimeout": 5000,
    "idempotencyTtlSeconds": 86400,
    "maxRetries": 3,
    "retryDelayMs": 1000
  },
  "scatterGather": {
    "aggregations": [
      {
        "trigger": "EVENT_CREATED",
        "expects": ["GEOCODED_SUCCESS", "SOCIAL_EVENT_CREATED"]
      }
    ]
  },
  "port": 3005
}
